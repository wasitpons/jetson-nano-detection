# --- Python ------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/

# --- Editors / OS ------------------------------------------------------------
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo
*.bak
*.tmp

# --- Runtime artifacts (generated; never commit) ----------------------------
logs/*.jsonl
logs/*.log
outputs/*.png
outputs/*.jpg
outputs/*.jpeg
reports/*.md
reports/*.json
# Keep the directories themselves in git via .gitkeep:
!**/.gitkeep

# --- Model artifacts ---------------------------------------------------------
# Engines must be rebuilt on each Jetson/JetPack/TRT change; the metadata
# captures the device fingerprint. Both are per-board and never ship in git.
# ONNX files ARE tracked — they're the portable source the pipeline converts
# to .engine on the target. (~10-50 MB each; consider Git LFS if > 50 MB.)
models/*.engine
models/*.build.log
models/*.engine_metadata.json

# --- Claude session state ---------------------------------------------------
CLAUDE.md
.claude/
